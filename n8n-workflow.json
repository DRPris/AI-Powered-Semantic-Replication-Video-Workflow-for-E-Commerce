      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        2650,
        300
      ],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "wait-video-gen",
