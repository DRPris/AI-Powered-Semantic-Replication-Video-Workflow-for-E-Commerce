      "name": "Slack通知",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.1,
      "position": [
        5850,
        300
      ],
      "parameters": {
        "channel": "={{ $env.SLACK_CHANNEL_ID }}",
        "text": "✅ 视频复刻工作流已完成！\n\n项目ID: {{ $json.project_id }}\n最终视频: {{ $json.result?.final_video_url || '查看详情' }}",
