{
  "name": "视频语义复刻工作流",
  "nodes": [
    {
      "id": "webhook-start",
      "name": "Webhook触发器",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "webhookId": "start-video-replication",
      "parameters": {
        "httpMethod": "POST",
        "path": "start-video-replication",
        "responseMode": "onReceived",
        "responseData": "allEntries",
        "options": {}
      }
    },
    {
      "id": "start-workflow",
      "name": "启动工作流",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        450,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/api/v1/start-workflow",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "project_id": "={{ $json.body.project_id || $json.body.project_name }}",
          "video_url": "={{ $json.body.video_url }}",
          "product_image_url": "={{ $json.body.product_image_url }}",
          "mode": "={{ $json.body.mode || 'full' }}"
        },
        "options": {
          "timeout": 120000
        }
      }
    },
    {
      "id": "wait-stage1",
      "name": "等待阶段一完成",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        650,
        300
      ],
      "parameters": {
        "resume": "afterTimeInterval",
        "amount": 30,
        "unit": "seconds"
      },
      "webhookId": "wait-stage1-resume"
    },
    {
      "id": "generate-script",
      "name": "生成复刻脚本",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        850,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/api/v1/generate-script",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "project_id": "={{ $('启动工作流').item.json.project_id }}"
        },
        "options": {
          "timeout": 300000
        }
      }
    },
    {
      "id": "convert-prompts",
      "name": "转换提示词",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1050,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/api/v1/convert-prompts",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "project_id": "={{ $('启动工作流').item.json.project_id }}"
        },
        "options": {
          "timeout": 300000
        }
      }
    },
    {
      "id": "loop-prompt-review-init",
      "name": "初始化提示词审核轮询",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [
        1250,
        300
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "loop_count",
              "value": 0,
              "type": "number"
            },
            {
              "name": "max_loops",
              "value": 288,
              "type": "number"
            },
            {
              "name": "project_id",
              "value": "={{ $('启动工作流').item.json.project_id }}",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "loop-prompt-review",
      "name": "提示词审核轮询",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1450,
        300
      ],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "wait-prompt-review",
      "name": "等待5分钟-提示词审核",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [
        1650,
        300
      ],
      "parameters": {
        "resume": "afterTimeInterval",
        "amount": 5,
        "unit": "minutes"
      },
      "webhookId": "wait-prompt-review-resume"
    },
    {
      "id": "check-prompt-status",
      "name": "查询提示词审核状态",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1850,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "http://localhost:8000/api/v1/project/{{ $json.project_id }}/review-status",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "review_type",
              "value": "prompt"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "if-prompt-approved",
      "name": "提示词审核通过",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2050,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-1",
              "leftValue": "={{ $json.all_approved }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        }
      }
    },
    {
      "id": "increment-prompt-loop",
      "name": "增加提示词轮询计数",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [
        1850,
        500
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "loop_count",
              "value": "={{ $json.loop_count + 1 }}",
              "type": "number"
            },
            {
              "name": "max_loops",
              "value": "={{ $json.max_loops }}",
              "type": "number"
            },
            {
              "name": "project_id",
              "value": "={{ $json.project_id }}",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "check-prompt-timeout",
      "name": "检查提示词轮询超时",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2050,
        500
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-1",
              "leftValue": "={{ $json.loop_count }}",
              "rightValue": "={{ $json.max_loops }}",
              "operator": {
                "type": "number",
                "operation": "lt"
              }
            }
          ]
        }
      }
    },
    {
      "id": "notify-prompt-timeout",
      "name": "提示词审核超时通知",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [
        2250,
        600
      ],
      "parameters": {}
    },
    {
      "id": "generate-shots",
      "name": "生成分镜视频",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        2250,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/api/v1/generate-shots",
        "sendBody": true,
        "contentType": "json",
        "body": {
          "project_id": "={{ $('启动工作流').item.json.project_id }}"
        },
        "options": {
          "timeout": 300000
        }
      }
    },
    {
      "id": "loop-video-gen-init",
      "name": "初始化视频生成轮询",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.2,
      "position": [
        2450,
        300
      ],
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "loop_count",
              "value": 0,
              "type": "number"
            },
            {
              "name": "max_loops",
              "value": 360,
              "type": "number"
            },
            {
              "name": "job_id",
              "value": "={{ $('生成分镜视频').item.json.job_id }}",
              "type": "string"
            },
            {
              "name": "project_id",
              "value": "={{ $('启动工作流').item.json.project_id }}",
              "type": "string"
            }
          ]
        }
      }
    },
    {
      "id": "loop-video-gen",
