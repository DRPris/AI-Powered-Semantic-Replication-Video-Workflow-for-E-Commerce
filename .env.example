# =====================================================================
# 语义视频复刻工作流 - 环境变量模板
# 复制为 .env 并填入真实值；切勿将 .env 提交到版本控制
# =====================================================================

# ---------------------------------------------------------------------
# 网络代理（可选，仅当无法直连 Google/海外 API 时启用）
# ---------------------------------------------------------------------
# HTTP_PROXY=socks5h://127.0.0.1:1080
# HTTPS_PROXY=socks5h://127.0.0.1:1080
# ALL_PROXY=socks5h://127.0.0.1:1080

# ---------------------------------------------------------------------
# Gemini API（核心：视频/图像理解、Prompt 转换、审核）
# 在 https://aistudio.google.com/apikey 创建
# ---------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------------
# Qwen（阿里云百炼平台）- 分镜提示词自审核 / 兜底
# 在 https://bailian.console.aliyun.com/ 创建 API Key
# ---------------------------------------------------------------------
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ---------------------------------------------------------------------
# KIE AI（统一调用 Kling/Seedance 的中转平台，备选）
# 在 https://kie.ai 注册
# ---------------------------------------------------------------------
KIE_API_KEY=your_kie_api_key_here
KIE_BASE_URL=https://api.kie.ai/api/v1

# ---------------------------------------------------------------------
# Seedance 直连 API（火山引擎方舟平台 - 主用图生视频平台）
# 在 https://console.volcengine.com/ark 创建 API Key（以 ark- 开头）
# ---------------------------------------------------------------------
SEEDANCE_API_KEY=ark-your_seedance_api_key_here
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# ---------------------------------------------------------------------
# Kling 官方 API（国内版 klingai.com）- 首尾帧双锚定平台
# 在 https://klingai.com/dev-center 申请 AccessKey / SecretKey（JWT HS256 签名）
# ---------------------------------------------------------------------
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here
KLING_BASE_URL=https://api-beijing.klingai.com
KLING_MODEL=kling-v3
KLING_MODE=std

# ---------------------------------------------------------------------
# 通义万相 Wan 2.7 图生视频（兜底平台，DashScope 百炼，复用 Qwen Key）
# ---------------------------------------------------------------------
WAN_API_KEY=your_wan_api_key_here
WAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
WAN_MODEL=wan2.7-i2v-2026-04-25
WAN_RESOLUTION=720P
ENABLE_WAN_FALLBACK=true

# ---------------------------------------------------------------------
# Airtable（项目数据存储 / 工作流状态驱动）
# 在 https://airtable.com/create/tokens 申请个人访问令牌（pat 开头）
# ---------------------------------------------------------------------
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here

# ---------------------------------------------------------------------
# Creatomate（已弃用，保留占位以兼容老代码）
# ---------------------------------------------------------------------
CREATOMATE_API_KEY=

# ---------------------------------------------------------------------
# FFmpeg（视频合成必需）
# 默认使用 PATH 中的 ffmpeg；如需指定二进制路径请填绝对路径
# ---------------------------------------------------------------------
FFMPEG_BIN_PATH=ffmpeg
FFMPEG_TEMP_DIR=./tmp

# ---------------------------------------------------------------------
# 阿里云 OSS（素材存储）
# 在 https://oss.console.aliyun.com 创建 RAM 子账号 AccessKey
# ---------------------------------------------------------------------
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_CDN_DOMAIN=

# ---------------------------------------------------------------------
# 背景去除（可选，rembg 本地为主，remove.bg 作为降级）
# ---------------------------------------------------------------------
REMOVEBG_API_KEY=

# ---------------------------------------------------------------------
# fal.ai Tripo3D（仅 scripts/product_to_3d.py / generate_3d_model.py /
#   render_3d_views.py 等 3D 建模脚本使用，可选）
# 在 https://fal.ai/dashboard/keys 申请
# ---------------------------------------------------------------------
FAL_KEY=
# 3D 建模脚本运行时指定的 Airtable 项目 Record ID
PROJECT_ID=

# ---------------------------------------------------------------------
# 关键帧生成（Stage 3.5）
# ---------------------------------------------------------------------
KEYFRAME_IMAGE_MODEL=gpt-image-2-image-to-image
# 视频生成首帧策略：
# - Seedance + ENABLE_KEYFRAME_STAGE=False -> 首尾帧衔接模式
# - Seedance + ENABLE_KEYFRAME_STAGE=True  -> 关键帧图生视频模式
# - Kling    + ENABLE_KEYFRAME_STAGE=True  -> 首尾双锚定模式（推荐）
ENABLE_KEYFRAME_STAGE=true

# ---------------------------------------------------------------------
# 商品视频理解（Stage 1）
# ---------------------------------------------------------------------
ENABLE_PRODUCT_VIDEO_ANALYSIS=true
PRODUCT_VIDEO_MAX_BYTES=18874368

# ---------------------------------------------------------------------
# 服务监听
# ---------------------------------------------------------------------
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# Prompts 目录（可选，留空则使用默认 ./prompts）
PROMPTS_DIR=

# ---------------------------------------------------------------------
# Suno AI 音乐生成（BGM，可选）
# 在 https://sunoapi.org 注册并获取 API Key
# ---------------------------------------------------------------------
SUNO_API_KEY=
SUNO_BASE_URL=https://api.sunoapi.org
SUNO_MODEL=V4_5ALL
ENABLE_BGM=false
BGM_VOLUME=0.3

# ---------------------------------------------------------------------
# OST（On-Screen Text）/ 字幕叠加 - Stage 5 后处理
# ---------------------------------------------------------------------
# 将原始视频的屏幕文字叠加到合成视频上
ENABLE_OST_OVERLAY=true
# 将原始视频的旁白/对话以字幕形式叠加到合成视频上
ENABLE_SUBTITLE_OVERLAY=true
# 字幕字体：archivo_black（饱满圆润，默认） / anton（超粗压缩） / oswald / poppins
SUBTITLE_FONT=archivo_black

# OST 本地化：基于 ProductBrief 将原商品专有名词改写为新商品文案
ENABLE_OST_LOCALIZATION=true
OST_LOCALIZATION_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------
# Product Brief Agent（Stage 1.0）- 商品分析智能体
# ---------------------------------------------------------------------
ENABLE_PRODUCT_AGENT=true
PRODUCT_AGENT_MAX_LOOPS=3
PRODUCT_AGENT_TIMEOUT_SEC=120
PRODUCT_AGENT_ENABLE_WEB_SEARCH=true
PRODUCT_AGENT_REQUIRE_USER_CONFIRMATION=false

# ---------------------------------------------------------------------
# Web Search Provider（供 Product Agent 的 web_search_brand 工具使用）
# 在 https://app.tavily.com 注册并获取 API Key
# ---------------------------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here

# ---------------------------------------------------------------------
# ElevenLabs Sound Effects - Stage 5 镜头内环境音生成（可选）
# 在 https://elevenlabs.io 申请，建议 API Key 仅授予
#   Sound Effects / User(Read) / Models(Access) 三项最小权限
# ---------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ENABLE_AMBIENT_AUDIO=true
AMBIENT_VOLUME=0.3
AMBIENT_MAX_DURATION_SEC=22
